generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Image {
  id        String   @id
  userId    String
  bucket    String
  path      String
  publicUrl String
  mimeType  String
  sizeBytes Int
  caption   String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id             String    @id
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           UserRole  @default(user)
  accessKey      String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Account        Account[]
  Image          Image[]
  Session        Session[]
  CarExpense     CarExpense[]
  TravelExpense  TravelExpense[]
}

enum UserRole {
  admin
  user
}

enum CarExpenseCategory {
  fuel
  parking
  toll
  insurance
  tax
  wash
  accessories
  other
}

enum TravelExpenseCategory {
  fuel
  toll
  parking
  accommodation
  food
  ferry
  other
}

model CarExpense {
  id            String             @id @default(cuid())
  userId        String
  carName       String
  licensePlate  String
  category      CarExpenseCategory
  amount        Float
  date          DateTime           @db.Date
  description   String
  liters        Float?
  pricePerLiter Float?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  User          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model TravelExpense {
  id            String                @id @default(cuid())
  userId        String
  tripName      String
  carName       String
  licensePlate  String
  category      TravelExpenseCategory
  amount        Float
  date          DateTime              @db.Date
  description   String
  liters        Float?
  pricePerLiter Float?
  distance      Float?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  User          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
